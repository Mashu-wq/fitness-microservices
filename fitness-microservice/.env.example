# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit .env to version control.

# ── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
GEMINI_API_KEY=your-gemini-api-key-here

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
# Change from default guest/guest before any production or shared deployment
RABBITMQ_USER=fitnessapp
RABBITMQ_PASS=change-me-strong-password

# ── MongoDB ──────────────────────────────────────────────────────────────────
# These are used if you add MongoDB authentication (recommended for production)
MONGO_USER=fitnessapp
MONGO_PASS=change-me-strong-password

# ── Redis ────────────────────────────────────────────────────────────────────
# Defaults match the docker-compose service name; override if using external Redis
REDIS_HOST=redis
REDIS_PORT=6379
