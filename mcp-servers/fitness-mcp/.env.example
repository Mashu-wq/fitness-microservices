# MCP server environment variables.
# The values in .claude/settings.json already point to localhost defaults
# so you only need this file if you want to override them.
#
# Copy to .env — it is gitignored.

# MongoDB
MONGODB_URI=mongodb://localhost:27017

# RabbitMQ management API
RABBITMQ_HOST=localhost
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Microservice base URLs (no trailing slash)
EUREKA_URL=http://localhost:8761
CONFIGSERVER_URL=http://localhost:8888
GATEWAY_URL=http://localhost:8080
USERSERVICE_URL=http://localhost:8081
ACTIVITYSERVICE_URL=http://localhost:8082
AISERVICE_URL=http://localhost:8083
ZIPKIN_URL=http://localhost:9411
